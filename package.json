{
  "name": "constel-db",
  "version": "0.6.2",
  "type": "module",
  "description": "con§tel — herramienta colaborativa de análisis temático de corpus textuales",
  "private": true,
  "scripts": {
    "dev": "npm run version && netlify dev",
    "build": "echo 'No build step needed'",
    "version": "node -e \"import('fs').then(fs=>fs.writeFileSync('public/version.json',JSON.stringify({version:JSON.parse(fs.readFileSync('package.json','utf8')).version})+'\\n'))\""
  },
  "keywords": [
    "thematic-analysis",
    "qualitative-research",
    "corpus",
    "annotation",
    "concept-mapping",
    "collaborative"
  ],
  "author": "Herbert Spencer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amereida/constel-db.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@netlify/functions": "^2.0.0",
    "marked-footnote": "^1.4.0",
    "postgres": "^3.4.0"
  }
}
